# Copy this to .env and fill in your values — NEVER commit .env to git
VITE_API_BASE_URL=http://192.168.1.10
VITE_MOCK_MODE=false

# Groq AI — https://console.groq.com
VITE_GROQ_API_KEY=gsk_...

# Optional: dedicated edge assistant backend (Whisper + orchestration)
# If unset, frontend falls back to VITE_API_BASE_URL
VITE_EDGE_API_BASE_URL=http://192.168.1.10:8088

# Porcupine wake word — https://console.picovoice.ai
VITE_PORCUPINE_ACCESS_KEY=...

# Shared login password for all devices
VITE_APP_PASSWORD=changeme123
