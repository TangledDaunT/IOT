# Edge assistant runtime
APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8088
CORS_ORIGINS=["http://localhost:5173"]

# Security controls (required)
SECURITY_API_TOKEN=replace_with_strong_random_token
SECURITY_MFA_CODE=replace_with_6_to_8_digit_code
SECURITY_MFA_CHALLENGE_TTL_SECONDS=180
SECURITY_MFA_TOKEN_TTL_SECONDS=600
SECURITY_MAX_AUDIO_BYTES=5242880
SECURITY_MAX_IMAGE_BYTES=1048576

# Existing IoT backend (ESP32)
IOT_BASE_URL=http://192.168.1.10
IOT_TIMEOUT_SECONDS=8.0
ROOM_SENSOR_PATH=/room/status
SMOKE_STATUS_PATH=/smoke/status
RELAY_STATUS_PATH=/relays/status
RELAY_TOGGLE_PATH=/relays/toggle

# Local Whisper (CPU)
WHISPER_MODEL=tiny.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=1
WHISPER_VAD_FILTER=true
WHISPER_LANGUAGE=en

# Groq
GROQ_API_KEY=REPLACE_WITH_GROQ_API_KEY
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
TTS_MODEL=canopylabs/orpheus-v1-english
TTS_VOICE=autumn
TTS_FORMAT=wav

# Nebius key (optional provider/fallback and your requested env inclusion)
NEBIUS_API_KEY=REPLACE_WITH_NEBIUS_API_KEY
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1

# 24/7 sensor worker
SENSOR_WORKER_ENABLED=true
SENSOR_POLL_INTERVAL_MS=2000

# Notification channel (optional)
NOTIFY_WEBHOOK_URL=

# Safety policy
AUTONOMY_ENABLED=true
AUTONOMY_SAFE_ACTIONS=["alerts","fan","lights"]
SMOKE_CONFIRMATION_REQUIRED=true
SMOKE_CONFIRM_YES_ACTION=fan_off

# AI Room System additions
ESP32_IP=192.168.1.100
ESP32_PORT=8000
MQTT_HOST=ad827adb37cb486d9a521c61763c31eb.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
