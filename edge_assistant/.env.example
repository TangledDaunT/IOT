# Edge assistant runtime
APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8088
CORS_ORIGINS=["*"]

# Existing IoT backend (ESP32)
IOT_BASE_URL=http://192.168.1.10
IOT_TIMEOUT_SECONDS=8.0
ROOM_SENSOR_PATH=/room/status
SMOKE_STATUS_PATH=/smoke/status
RELAY_STATUS_PATH=/relays/status
RELAY_TOGGLE_PATH=/relays/toggle

# Local Whisper (CPU)
WHISPER_MODEL=tiny.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=1
WHISPER_VAD_FILTER=true
WHISPER_LANGUAGE=en

# Groq
GROQ_API_KEY=REPLACE_WITH_GROQ_API_KEY
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
TTS_MODEL=canopylabs/orpheus-v1-english
TTS_VOICE=autumn
TTS_FORMAT=wav

# Nebius key (optional provider/fallback and your requested env inclusion)
NEBIUS_API_KEY=v1.CmMKHHN0YXRpY2tleS1lMDB0ZmhieWp0OXZ0Y3h3dmoSIXNlcnZpY2VhY2NvdW50LWUwMGt4Y2MzNjF0OWI3eXpmMTIMCOrk1s0GEKKip7ECOgsI6ufumAcQwMaUMEACWgNlMDA.AAAAAAAAAAFvRvy6MLtmVISsaR7skBFc6MMU3y3Iv9SIEo9ETOp65Iyd_P8KxX-pyNUzGq2qPehQa2nbhKfh9baHGEhQtosO
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1

# 24/7 sensor worker
SENSOR_WORKER_ENABLED=true
SENSOR_POLL_INTERVAL_MS=2000

# Notification channel (optional)
NOTIFY_WEBHOOK_URL=

# Safety policy
AUTONOMY_ENABLED=true
AUTONOMY_SAFE_ACTIONS=["alerts","fan","lights"]
SMOKE_CONFIRMATION_REQUIRED=true
SMOKE_CONFIRM_YES_ACTION=fan_off
